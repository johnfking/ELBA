-- LuaCov configuration
return {
  -- Only include source files, exclude tests
  include = {
    "^init%.lua$",
    "^LuaBots/",
    "^enums/"
  },
  
  -- Exclude test files and test utilities
  exclude = {
    "^spec/",
    "^test_",
    "^%.luarocks/"
  },
  
  -- Report configuration
  statsfile = "luacov.stats.out",
  reportfile = "luacov.report.out",
  
  -- Coverage thresholds
  codefromstrings = false
}
